<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Infant Jesus Learning Academy</title>

    <!-- Favicon -->
    <link rel="icon" href="@Url.Content("~/images/seal.png")" type="image/x-icon">

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Syncfusion -->
    <link href="https://cdn.syncfusion.com/ej2/material.css" rel="stylesheet" />

    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <!-- Animate.css -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <!-- Dashboard CSS (layout only) -->
    <link rel="stylesheet" href="@Url.Content("~/dashboard/css/dashboard.css")?v=@Guid.NewGuid()">

    <!-- IJED Theme (colors, branding — loads last) -->
    <link rel="stylesheet" href="~/css/theme-ijed.css" asp-append-version="true">
</head>
<body>

    <!-- ═══════════════════════════════════════════════════════════
         SIDEBAR
    ═══════════════════════════════════════════════════════════ -->
    <aside class="sidebar" id="sidebar">

        <!-- Sidebar header: logo + school name -->
        <div class="sidebar-brand">
            <img src="@Url.Content("~/images/seal.png")" alt="IJED Seal" class="sidebar-brand-logo">
            <div class="sidebar-brand-text">
                <span class="sidebar-brand-name">IJED</span>
                <span class="sidebar-brand-sub">Learning Academy</span>
            </div>
        </div>

        <!-- Divider -->
        <div class="sidebar-divider"></div>

        <!-- Navigation -->
        <nav class="sidebar-nav">
            <ul class="sidebar-menu">

                <!-- Dashboard home -->
                <li class="sidebar-item">
                    @{
                        string dashLink = User.IsInRole("Admin") ? Url.Action("AdminDashboard", "Dashboard") :
                        User.IsInRole("Employee") ? Url.Action("EmployeeDashboard", "Dashboard") :
                        User.IsInRole("Teacher") ? Url.Action("TeacherDashboard", "Dashboard") :
                        User.IsInRole("Student") ? Url.Action("StudentDashboard", "Dashboard") :
                        Url.Action("Index", "Home");
                    }
                    <a href="@dashLink" class="sidebar-link @(ViewBag.PageTitle == null ? "active" : "")">
                        <span class="sidebar-icon"><i class="fas fa-home"></i></span>
                        <span class="sidebar-label">Dashboard</span>
                    </a>
                </li>

                <!-- Admin-only: Register account -->
                @if (User.IsInRole("Admin"))
                {
                    <li class="sidebar-item">
                        <a href="@Url.Action("Register", "Account")" class="sidebar-link @(ViewBag.PageTitle == "Register" ? "active" : "")">
                            <span class="sidebar-icon"><i class="fas fa-user-plus"></i></span>
                            <span class="sidebar-label">Register Account</span>
                        </a>
                    </li>
                }

                <!-- Courses, Subjects, Classes (Admin + Employee) -->
                @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                {
                    <li class="sidebar-section-label">Academic</li>

                    <li class="sidebar-item">
                        <a href="@Url.Action("Index", "Courses")" class="sidebar-link @(ViewBag.PageTitle == "Courses" ? "active" : "")">
                            <span class="sidebar-icon"><i class="fas fa-book"></i></span>
                            <span class="sidebar-label">Courses</span>
                        </a>
                    </li>

                    <li class="sidebar-item">
                        <a href="@Url.Action("Index", "Subjects")" class="sidebar-link @(ViewBag.PageTitle == "Subjects" ? "active" : "")">
                            <span class="sidebar-icon"><i class="fas fa-book-open"></i></span>
                            <span class="sidebar-label">Subjects</span>
                        </a>
                    </li>

                    <li class="sidebar-item">
                        <a href="@Url.Action("Index", "SchoolClasses")" class="sidebar-link @(ViewBag.PageTitle == "SchoolClasses" ? "active" : "")">
                            <span class="sidebar-icon"><i class="fas fa-school"></i></span>
                            <span class="sidebar-label">School Classes</span>
                        </a>
                    </li>
                }

                <!-- Students, Grades, Attendance (Admin + Employee) -->
                @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                {
                    <li class="sidebar-section-label">Students</li>

                    <li class="sidebar-item">
                        <a href="@Url.Action("Index", "Students")" class="sidebar-link @(ViewBag.PageTitle == "Students" ? "active" : "")">
                            <span class="sidebar-icon"><i class="fas fa-user-graduate"></i></span>
                            <span class="sidebar-label">Students</span>
                        </a>
                    </li>

                    <li class="sidebar-item">
                        <a href="@Url.Action("Index", "Grades")" class="sidebar-link @(ViewBag.PageTitle == "Grade" ? "active" : "")">
                            <span class="sidebar-icon"><i class="fas fa-graduation-cap"></i></span>
                            <span class="sidebar-label">Grades</span>
                        </a>
                    </li>

                    <li class="sidebar-item">
                        <a href="@Url.Action("Index", "Attendance")" class="sidebar-link @(ViewBag.PageTitle == "Attendance" ? "active" : "")">
                            <span class="sidebar-icon"><i class="fas fa-calendar-check"></i></span>
                            <span class="sidebar-label">Attendance</span>
                        </a>
                    </li>
                }

                <!-- Student self-service -->
                @if (User.IsInRole("Student"))
                {
                    <li class="sidebar-section-label">My Records</li>

                    <li class="sidebar-item">
                        <a href="@Url.Action("MyGrades", "Grades")" class="sidebar-link @(ViewBag.PageTitle == "My Grades" ? "active" : "")">
                            <span class="sidebar-icon"><i class="fas fa-book-reader"></i></span>
                            <span class="sidebar-label">My Grades</span>
                        </a>
                    </li>

                    <li class="sidebar-item">
                        <a href="@Url.Action("MyAttendances", "Attendance")" class="sidebar-link @(ViewBag.PageTitle == "My Attendance" ? "active" : "")">
                            <span class="sidebar-icon"><i class="fas fa-clipboard-list"></i></span>
                            <span class="sidebar-label">My Attendance</span>
                        </a>
                    </li>
                }

                <!-- Staff management (Admin + Employee) -->
                @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                {
                    <li class="sidebar-section-label">Staff</li>

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="sidebar-item">
                            <a href="@Url.Action("Index", "Employees")" class="sidebar-link @(ViewBag.PageTitle == "Employees" ? "active" : "")">
                                <span class="sidebar-icon"><i class="fas fa-user-tie"></i></span>
                                <span class="sidebar-label">Employees</span>
                            </a>
                        </li>
                    }

                    <li class="sidebar-item">
                        <a href="@Url.Action("Index", "Teachers")" class="sidebar-link @(ViewBag.PageTitle == "Teachers" ? "active" : "")">
                            <span class="sidebar-icon"><i class="fas fa-chalkboard-teacher"></i></span>
                            <span class="sidebar-label">Teachers</span>
                        </a>
                    </li>
                }

                <!-- Alerts -->
                @if (User.IsInRole("Employee") || User.IsInRole("Admin"))
                {
                    <li class="sidebar-section-label">Alerts</li>

                    @if (User.IsInRole("Employee"))
                    {
                        <li class="sidebar-item">
                            <a href="@Url.Action("Create", "Alert")" class="sidebar-link">
                                <span class="sidebar-icon"><i class="fas fa-plus-circle"></i></span>
                                <span class="sidebar-label">Create Alert</span>
                            </a>
                        </li>
                        <li class="sidebar-item">
                            <a href="@Url.Action("ViewAlerts", "Alert")" class="sidebar-link">
                                <span class="sidebar-icon"><i class="fas fa-exclamation-triangle"></i></span>
                                <span class="sidebar-label">View Alerts</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="sidebar-item">
                            <a href="@Url.Action("UnresolvedAlerts", "Alert")" class="sidebar-link">
                                <span class="sidebar-icon"><i class="fas fa-bell"></i></span>
                                <span class="sidebar-label">Manage Alerts</span>
                            </a>
                        </li>
                    }
                }

            </ul>
        </nav>

        <!-- Sidebar footer: user info + logout -->
        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="sidebar-user-avatar">
                    @{
                        var initials = "";
                        if (User.Identity.IsAuthenticated && User.Identity.Name != null)
                        {
                            var parts = User.Identity.Name.Split('@')[0].Split('.');
                            initials = parts.Length >= 2
                            ? (parts[0][0].ToString() + parts[1][0].ToString()).ToUpper()
                            : User.Identity.Name.Substring(0, Math.Min(2, User.Identity.Name.Length)).ToUpper();
                        }
                    }
                    <span>@initials</span>
                </div>
                <div class="sidebar-user-info">
                    <span class="sidebar-user-name">@User.Identity.Name</span>
                    <span class="sidebar-user-role">
                        @(User.IsInRole("Admin") ? "Administrator" :
                                                User.IsInRole("Employee") ? "Employee" :
                                                User.IsInRole("Teacher") ? "Teacher" :
                                                User.IsInRole("Student") ? "Student" : "User")
                    </span>
                </div>
            </div>
            <a href="@Url.Action("Logout", "Account")" class="sidebar-logout" title="Logout">
                <i class="fas fa-sign-out-alt"></i>
            </a>
        </div>
    </aside>

    <!-- ═══════════════════════════════════════════════════════════
         TOPBAR
    ═══════════════════════════════════════════════════════════ -->
    <div class="dash-topbar">
        <!-- Left: hamburger + page title -->
        <div class="topbar-left">
            <button class="topbar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
                <i class="fas fa-bars"></i>
            </button>
            <div class="topbar-title-group">
                <h1 class="topbar-title">@(ViewBag.PageTitle ?? "Dashboard")</h1>
                <!-- Breadcrumb -->
                <nav class="topbar-breadcrumb" aria-label="breadcrumb">
                    <a href="@dashLink">Dashboard</a>
                    @if (ViewBag.PageTitle != null)
                    {
                        <span class="breadcrumb-sep">/</span>
                        <span>@ViewBag.PageTitle</span>
                    }
                    @if (ViewBag.SubPageTitle != null)
                    {
                        <span class="breadcrumb-sep">/</span>
                        <span>@ViewBag.SubPageTitle</span>
                    }
                </nav>
            </div>
        </div>

        <!-- Right: notifications + user avatar -->
        <div class="topbar-right">
            @if (User.IsInRole("Admin"))
            {
                <div class="topbar-notif" id="topbarNotif">
                    @await Component.InvokeAsync("Notifications")
                </div>
            }

            <!-- User avatar dropdown -->
            <div class="dropdown topbar-user-dropdown">
                <button class="topbar-avatar-btn dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="topbar-avatar">@initials</div>
                </button>
                <ul class="dropdown-menu dropdown-menu-end topbar-dropdown-menu">
                    <li class="dropdown-header">
                        <strong>@User.Identity.Name</strong>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item" href="@Url.Action("ChangeUser", "Account")">
                            <i class="fas fa-user me-2"></i>Profile
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" href="@Url.Action("ChangePassword", "Account")">
                            <i class="fas fa-lock me-2"></i>Change Password
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")">
                            <i class="fas fa-sign-out-alt me-2"></i>Logout
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         MAIN CONTENT WRAPPER
    ═══════════════════════════════════════════════════════════ -->
    <div class="content-wrapper" id="contentWrapper">
        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         SCRIPTS
    ═══════════════════════════════════════════════════════════ -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.syncfusion.com/ej2/dist/ej2.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/js/all.min.js"></script>
    <script src="@Url.Content("~/dashboard/js/dashboard.js")?v=@Guid.NewGuid()"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
