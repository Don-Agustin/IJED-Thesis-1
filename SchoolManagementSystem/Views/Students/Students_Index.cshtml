@{
    Layout = "_Dashboard";
    ViewBag.PageTitle = "Students";
    ViewBag.SubPageTitle = "Index";
}

@using Newtonsoft.Json
@model IEnumerable<SchoolManagementSystem.Data.Entities.Student>

@{
    ViewData["Title"] = "Students List";
    var jsonSettings = new JsonSerializerSettings
    {
        ReferenceLoopHandling = ReferenceLoopHandling.Ignore,
        Formatting = Formatting.Indented
    };
    var serializedData = JsonConvert.SerializeObject(Model, jsonSettings);
}

<!-- Page heading -->
<div class="page-heading">
    <div class="page-heading-left">
        <div class="heading-icon"><i class="fas fa-user-graduate"></i></div>
        <h2>Students</h2>
        <span class="count-badge">@Model.Count()</span>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="fas fa-plus me-1"></i>Add Student
    </a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-user-graduate"></i>
        <p>No students found. Add the first one to get started.</p>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div id="Grid" style="border-radius: 0 0 12px 12px; overflow: hidden;"></div>
        </div>
    </div>
}

@section Scripts {
    <script id="profilePictureTemplate" type="text/x-template">
        <img src="${ImageFullPath}" alt="Profile" style="width:38px;height:38px;border-radius:50%;object-fit:cover;border:2px solid #fdf0f2;" />
    </script>
    <script id="actionTemplate" type="text/x-template">
        <div style="display:flex;gap:4px;justify-content:center;">
            <a href="/Students/Edit/${Id}"    class="btn btn-warning btn-sm" title="Edit"><i class="fas fa-edit"></i></a>
            <a href="/Students/Delete/${Id}"  class="btn btn-danger  btn-sm" title="Delete"><i class="fas fa-trash"></i></a>
            <a href="/Students/Details/${Id}" class="btn btn-primary btn-sm" title="Details"><i class="fas fa-eye"></i></a>
        </div>
    </script>
    <script id="statusTemplate" type="text/x-template">
        <span class="badge ${StatusText === 'Active' ? 'badge-pass' : StatusText === 'Pending' ? 'badge-pending' : 'badge-fail'}">${StatusText}</span>
    </script>

    <script>
        $(document).ready(function () {
            var data = @Html.Raw(serializedData);
            data.forEach(function (s) {
                switch (s.Status) {
                    case 0: s.StatusText = "Pending"; break;
                    case 1: s.StatusText = "Active";  break;
                    case 2: s.StatusText = "Inactive"; break;
                    default: s.StatusText = String(s.Status);
                }
            });

            var grid = new ej.grids.Grid({
                dataSource: data,
                allowPaging: true,
                allowSorting: true,
                allowFiltering: true,
                filterSettings: { type: 'Menu' },
                pageSettings: { pageSize: 10 },
                toolbar: ['Search'],
                columns: [
                    { field: "ImageFullPath",          headerText: "Photo",       width: 80,  textAlign: "Center", template: "#profilePictureTemplate" },
                    { field: "FirstName",               headerText: "First Name",  width: 130 },
                    { field: "LastName",                headerText: "Last Name",   width: 130 },
                    { field: "FormattedEnrollmentDate", headerText: "Enrolled",    width: 130 },
                    { field: "StatusText",              headerText: "Status",      width: 110, template: "#statusTemplate" },
                    { field: "SchoolClass.ClassName",   headerText: "Class",       width: 140 },
                    { headerText: "Actions",            width: 160, textAlign: "Center", template: "#actionTemplate", allowSorting: false, allowFiltering: false }
                ]
            });

            grid.appendTo("#Grid");
        });
    </script>
}
