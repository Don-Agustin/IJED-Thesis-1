@{
    Layout = "_Dashboard";
    ViewBag.PageTitle = "Attendance";
    ViewBag.SubPageTitle = "Index";
}

@model IEnumerable<SchoolManagementSystem.Models.StudentAttendanceViewModel>

<!-- Page heading -->
<div class="page-heading">
    <div class="page-heading-left">
        <div class="heading-icon"><i class="fas fa-calendar-check"></i></div>
        <h2>Attendance</h2>
        @if (Model.Any())
        {
            <span class="count-badge">@Model.Count()</span>
        }
    </div>
    <a asp-action="AddAttendance" class="btn btn-primary btn-sm">
        <i class="fas fa-plus me-1"></i>Record Attendance
    </a>
</div>

<!-- Card with filter in header -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span>Attendance List</span>
        <form asp-action="Index" method="get" class="d-flex align-items-center gap-2">
            <label for="SchoolClassId" class="form-label mb-0" style="font-size:13px; color:#fff; white-space:nowrap;">Class:</label>
            <select id="SchoolClassId" name="classId" class="form-select form-select-sm" style="min-width:160px; background:#fff; color:#1a0a0e;">
                <option value="">— All Classes —</option>
                @foreach (var schoolClass in ViewBag.Classes)
                {
                    <option value="@schoolClass.Value">@schoolClass.Text</option>
                }
            </select>
            <button type="submit" class="btn btn-sm btn-light">Filter</button>
        </form>
    </div>

    <div class="card-body p-0">
        @if (Model.Any())
        {
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Total Absences</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var status     = item.OverallAttendanceStatus();
                        var isOk       = status?.ToString().Contains("Good") == true || status?.ToString().Contains("Pass") == true;
                        var isWarn     = item.TotalAbsences > 0 && !isOk;
                        var badgeCls   = isOk ? "badge badge-pass" : isWarn ? "badge badge-fail" : "badge badge-pending";
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-xs">
                                        @(item.Student.FirstName[0].ToString())@(item.Student.LastName[0].ToString())
                                    </div>
                                    @item.Student.FirstName @item.Student.LastName
                                </div>
                            </td>
                            <td>
                                @if (item.TotalAbsences > 0)
                                {
                                    <span class="text-danger fw-semibold">@item.TotalAbsences</span>
                                }
                                else
                                {
                                    <span class="text-success">0</span>
                                }
                            </td>
                            <td><span class="@badgeCls">@status</span></td>
                            <td class="text-center">
                                <a class="btn btn-primary btn-sm"
                                   asp-action="Details"
                                   asp-route-studentId="@item.Student.Id"
                                   title="View Details">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-calendar-check"></i>
                <p>Select a class above to view attendance records.</p>
            </div>
        }
    </div>
</div>
