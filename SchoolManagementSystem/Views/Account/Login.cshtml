@{
    Layout = "_LayoutLogin";
}

@model SchoolManagementSystem.Models.LoginViewModel
@{
    ViewData["Title"] = "Email Log In";
    var loginType = ViewData["LoginType"]?.ToString() ?? "email";
    var isAdmin = loginType == "admin";
    var cardTitle = isAdmin ? "Admin Log In" : "Email Log In";
    var backAction = "LoginSelection";
}

<div class="login-selection-wrapper">
    <!-- Faded watermark logo -->
    <div class="login-watermark">
        <img src="~/images/seal.png" alt="IJED Seal" />
    </div>

    <!-- Login form card -->
    <div class="login-form-card" role="main">
        <!-- Back button -->
        <a href="@Url.Action(backAction, "Account")" class="login-back-btn" aria-label="Go back">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                 stroke-linejoin="round" width="20" height="20">
                <path d="M15 18l-6-6 6-6"/>
            </svg>
        </a>

        <h2 class="login-form-title">@cardTitle</h2>

        <form method="post" asp-action="Login" asp-route-loginType="@loginType" novalidate>
            <input type="hidden" name="LoginType" value="@loginType" />
            <div asp-validation-summary="ModelOnly" class="login-validation-summary"></div>

            <div class="login-field-group">
                <label asp-for="Username" class="login-field-label">Email Address</label>
                <input asp-for="Username"
                       type="email"
                       class="login-field-input"
                       placeholder="Enter your email"
                       autocomplete="email" />
                <span asp-validation-for="Username" class="login-field-error"></span>
            </div>

            <div class="login-field-group">
                <label asp-for="Password" class="login-field-label">Password</label>
                <div class="login-password-wrapper">
                    <input asp-for="Password"
                           type="password"
                           class="login-field-input"
                           placeholder="Enter your password"
                           autocomplete="current-password"
                           id="passwordField" />
                    <button type="button" class="login-toggle-password" aria-label="Toggle password visibility" onclick="togglePassword()">
                        <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round" width="18" height="18">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="login-field-error"></span>
            </div>

            <div class="login-options-row">
                <label class="login-remember-label">
                    <input asp-for="RememberMe" type="checkbox" class="login-checkbox" />
                    <span class="login-checkbox-custom"></span>
                    Remember my preference
                </label>
                <a asp-action="RecoverPassword" class="login-forgot-link">Forgot Password?</a>
            </div>

            <button type="submit" class="login-submit-btn">
                Log in
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function togglePassword() {
            const field = document.getElementById('passwordField');
            const icon = document.getElementById('eyeIcon');
            if (field.type === 'password') {
                field.type = 'text';
                icon.innerHTML = `
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                    <line x1="1" y1="1" x2="23" y2="23"/>`;
            } else {
                field.type = 'password';
                icon.innerHTML = `
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>`;
            }
        }
    </script>
}
