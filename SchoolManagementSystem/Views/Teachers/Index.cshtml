@{
    Layout = "_Dashboard";
    ViewBag.PageTitle = "Teachers";
    ViewBag.SubPageTitle = "Index";
}

@using Newtonsoft.Json
@model IEnumerable<SchoolManagementSystem.Data.Entities.Teacher>

@{
    ViewData["Title"] = "Teachers List";
    var jsonSettings = new JsonSerializerSettings { ReferenceLoopHandling = ReferenceLoopHandling.Ignore };
    var serializedData = JsonConvert.SerializeObject(Model, jsonSettings);
}

<div class="page-heading">
    <div class="page-heading-left">
        <div class="heading-icon"><i class="fas fa-chalkboard-teacher"></i></div>
        <h2>Teachers</h2>
        <span class="count-badge">@Model.Count()</span>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="fas fa-plus me-1"></i>Add Teacher
    </a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-chalkboard-teacher"></i>
        <p>No teachers found. Add the first one to get started.</p>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div id="Grid" style="border-radius: 0 0 12px 12px; overflow: hidden;"></div>
        </div>
    </div>
}

@section Scripts {
    <script id="profilePictureTemplate" type="text/x-template">
        <img src="${ImageFullPath}" alt="Profile" style="width:38px;height:38px;border-radius:50%;object-fit:cover;border:2px solid #fdf0f2;" />
    </script>
    <script id="actionTemplate" type="text/x-template">
        <div style="display:flex;gap:4px;justify-content:center;">
            <a href="/Teachers/Edit/${Id}"    class="btn btn-warning btn-sm" title="Edit"><i class="fas fa-edit"></i></a>
            <a href="/Teachers/Delete/${Id}"  class="btn btn-danger  btn-sm" title="Delete"><i class="fas fa-trash"></i></a>
            <a href="/Teachers/Details/${Id}" class="btn btn-primary btn-sm" title="Details"><i class="fas fa-eye"></i></a>
        </div>
    </script>
    <script id="statusTemplate" type="text/x-template">
        <span class="badge ${StatusText === 'Active' ? 'badge-pass' : StatusText === 'Pending' ? 'badge-pending' : 'badge-fail'}">${StatusText}</span>
    </script>

    <script>
        $(document).ready(function () {
            var data = @Html.Raw(serializedData);
            data.forEach(function (t) {
                switch (t.Status) {
                    case 0: t.StatusText = "Pending"; break;
                    case 1: t.StatusText = "Active";  break;
                    case 2: t.StatusText = "Inactive"; break;
                    default: t.StatusText = String(t.Status);
                }
            });

            new ej.grids.Grid({
                dataSource: data,
                allowPaging: true, allowSorting: true, allowFiltering: true,
                filterSettings: { type: 'Menu' },
                pageSettings: { pageSize: 10 },
                toolbar: ['Search'],
                columns: [
                    { field: "ImageFullPath",    headerText: "Photo",      width: 80,  textAlign: "Center", template: "#profilePictureTemplate" },
                    { field: "FirstName",         headerText: "First Name", width: 130 },
                    { field: "LastName",          headerText: "Last Name",  width: 130 },
                    { field: "AcademicDegree",    headerText: "Degree",     width: 130 },
                    { field: "FormattedHireDate", headerText: "Hire Date",  width: 120 },
                    { field: "StatusText",        headerText: "Status",     width: 110, template: "#statusTemplate" },
                    { headerText: "Actions",      width: 160, textAlign: "Center", template: "#actionTemplate", allowSorting: false, allowFiltering: false }
                ]
            }).appendTo("#Grid");
        });
    </script>
}
