@{
    Layout = "_Dashboard";
    ViewBag.Title = "Teacher Dashboard";
    ViewBag.PageTitle = "Dashboard";
}

@model SchoolManagementSystem.Models.TeacherDashboardViewModel

@{
    var today       = DateTime.Today;
    var events      = Model.CalendarEvents.ToList();
    var firstDay    = new DateTime(today.Year, today.Month, 1);
    var daysInMonth = DateTime.DaysInMonth(today.Year, today.Month);
    int startOffset = (int)firstDay.DayOfWeek;
}

<!-- ═══════════ WELCOME BAR ═══════════ -->
<div class="t-welcome-bar mb-3">
    <div class="t-welcome-left">
        <div class="t-avatar">@(Model.WelcomeName.Length > 0 ? Model.WelcomeName[0].ToString().ToUpper() : "T")</div>
        <div>
            <span class="t-welcome-label">Welcome,</span>
            <span class="t-welcome-name">Teacher @Model.WelcomeName</span>
        </div>
    </div>
    @if (Model.AdvisingClasses.Any())
    {
        var first = Model.AdvisingClasses.First();
        <div class="t-current-period">
            <i class="fas fa-chalkboard me-1"></i>
            Current: @first.SchoolClass.ClassName
            @if (first.Subjects.Any()) { <text>– @first.Subjects.First().Name</text> }
        </div>
    }
    <div class="t-search-box">
        <i class="fas fa-search"></i>
        <input type="text" placeholder="Search..." />
    </div>
</div>

<!-- ═══════════ MY ADVISING CLASSES ═══════════ -->
<div class="section-heading mb-2">
    <i class="fas fa-chalkboard-teacher me-2"></i>Home Dashboard – Overview
</div>
<div class="t-class-cards mb-4">
    @foreach (var cls in Model.AdvisingClasses)
    {
        <div class="t-class-card">
            <div class="t-class-icon"><i class="fas fa-laptop-code"></i></div>
            <div class="t-class-name">@cls.SchoolClass.ClassName</div>
            @if (cls.Subjects.Any())
            {
                <div class="t-class-subject">@cls.Subjects.First().Name</div>
            }
            <div class="t-class-meta">@cls.StudentCount students</div>
            <a asp-action="TeacherCourses" asp-controller="Dashboard"
               asp-route-classId="@cls.SchoolClass.Id"
               class="btn btn-primary btn-sm w-100 mt-2">
                <i class="fas fa-book me-1"></i>Manage Materials
            </a>
        </div>
    }
    @if (!Model.AdvisingClasses.Any())
    {
        <div class="t-class-card t-class-card--empty">
            <i class="fas fa-plus-circle" style="font-size:28px;opacity:.4"></i>
            <span style="font-size:13px;color:#9a8a8e">No classes assigned yet</span>
        </div>
    }
</div>

<!-- ═══════════ SCHEDULE + ACTIVITIES ═══════════ -->
<div class="section-heading mb-2">
    <i class="fas fa-calendar-day me-2"></i>Today's Timetable &amp; Tasks
</div>
<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span><i class="fas fa-clock me-2"></i>Schedule of the Day</span>
                <span class="badge-date">@today.ToString("dddd, MMM d")</span>
            </div>
            <div class="card-body p-0">
                <ul class="t-schedule-list">
                    @foreach (var item in Model.TodaySchedule)
                    {
                        <li class="t-schedule-item">
                            <span class="t-schedule-time">@item.Time</span>
                            <span class="t-dot t-dot--@item.Color"></span>
                            <span class="t-schedule-title">@item.Title</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">
                <i class="fas fa-tasks me-2"></i>Upcoming Activities &amp; Tasks
            </div>
            <div class="card-body p-0">
                <ul class="t-activity-list">
                    @foreach (var act in Model.UpcomingActivities)
                    {
                        <li class="t-activity-item @(act.IsDone ? "t-activity-item--done" : "")">
                            <i class="fas @act.Icon t-activity-icon"></i>
                            <span>@act.Title</span>
                            @if (act.IsDone)
                            {
                                <i class="fas fa-check-circle t-activity-done-icon ms-auto"></i>
                            }
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ MONTHLY CALENDAR ═══════════ -->
<div class="section-heading mb-2">
    <i class="fas fa-calendar-alt me-2"></i>Monthly Calendar &amp; Important Details
</div>
<div class="row g-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span>@today.ToString("MMMM yyyy")</span>
                <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#addEventModal">
                    <i class="fas fa-plus me-1"></i>Add Event
                </button>
            </div>
            <div class="card-body p-2">
                <div class="t-calendar">
                    @foreach (var d in new[]{"Sun","Mon","Tue","Wed","Thu","Fri","Sat"})
                    {
                        <div class="t-cal-header">@d</div>
                    }
                    @for (int i = 0; i < startOffset; i++)
                    {
                        <div class="t-cal-day t-cal-day--empty"></div>
                    }
                    @for (int day = 1; day <= daysInMonth; day++)
                    {
                        var cellDate  = new DateTime(today.Year, today.Month, day);
                        var dayEvents = events.Where(e => e.Date.Date == cellDate.Date).ToList();
                        var isToday   = cellDate.Date == today;
                        <div class="t-cal-day @(isToday ? "t-cal-day--today" : "")" data-date="@cellDate.ToString("yyyy-MM-dd")">
                            <span class="t-cal-num">@day</span>
                            @foreach (var ev in dayEvents)
                            {
                                <div class="t-cal-event t-cal-event--@ev.Color" title="@ev.Description">@ev.Title</div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header"><i class="fas fa-info-circle me-2"></i>Event Details</div>
            <div class="card-body p-0">
                @if (events.Any())
                {
                    <ul class="t-detail-list">
                        @foreach (var ev in events.OrderBy(e => e.Date).Take(6))
                        {
                            <li class="t-detail-item">
                                <span class="t-detail-dot t-cal-event--@ev.Color"></span>
                                <div class="t-detail-info">
                                    <span class="t-detail-date">@ev.Date.ToString("MMM d, yyyy")</span>
                                    <span class="t-detail-title">@ev.Title</span>
                                    @if (!string.IsNullOrEmpty(ev.Description))
                                    {
                                        <span class="t-detail-sub">@ev.Description</span>
                                    }
                                </div>
                                <div class="t-detail-actions">
                                    <button class="t-icon-btn" title="Edit"
                                            onclick="openEditEvent(@ev.Id,'@Html.Raw(ev.Title.Replace("'","\\'"))','@ev.Date.ToString("yyyy-MM-dd")','@ev.Color','@Html.Raw((ev.Description ?? "").Replace("'","\\'"))')">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <form asp-action="DeleteCalendarEvent" asp-controller="Dashboard" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@ev.Id" />
                                        <button type="submit" class="t-icon-btn t-icon-btn--danger" title="Delete"
                                                onclick="return confirm('Delete this event?')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="empty-state" style="padding:32px 16px">
                        <i class="fas fa-calendar-plus"></i>
                        <p>No events yet. Click Add Event.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ ADD EVENT MODAL ═══════════ -->
<div class="modal fade" id="addEventModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content t-modal">
            <form asp-action="AddCalendarEvent" asp-controller="Dashboard" method="post">
                <div class="modal-header t-modal-header">
                    <h5 class="modal-title" id="addEventLabel">
                        <i class="fas fa-calendar-plus me-2"></i>Add Calendar Event
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Event Title <span class="text-danger">*</span></label>
                        <input type="text" name="title" id="evTitle" class="form-control" required placeholder="e.g. Web Design Test" />
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-7">
                            <label class="form-label">Date <span class="text-danger">*</span></label>
                            <input type="date" name="date" id="evDate" class="form-control" required value="@today.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-5">
                            <label class="form-label">Color Tag</label>
                            <select name="color" id="evColor" class="form-select">
                                <option value="maroon">🔴 Class / Test</option>
                                <option value="amber">🟡 Meeting</option>
                                <option value="green">🟢 Activity</option>
                                <option value="blue">🔵 Prep / Other</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="form-label">Notes</label>
                        <input type="text" name="description" id="evDesc" class="form-control" placeholder="Optional details" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-save me-1"></i>Save Event</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function openEditEvent(id, title, date, color, desc) {
    document.getElementById('addEventLabel').innerHTML = '<i class="fas fa-edit me-2"></i>Edit Event';
    document.getElementById('evTitle').value = title;
    document.getElementById('evDate').value  = date;
    document.getElementById('evColor').value = color;
    document.getElementById('evDesc').value  = desc;
    new bootstrap.Modal(document.getElementById('addEventModal')).show();
}
</script>
}
