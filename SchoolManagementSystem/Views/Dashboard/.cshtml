@{
    Layout = "_StudentDashboard";
    ViewBag.Title = "Student Dashboard";
    ViewBag.PageTitle = "Home";
    ViewBag.ActivePage = "Home";

    // ── DB-READY: Populate these from DashboardViewModel / StudentController ──
    // In the controller action (DashboardController.StudentDashboard), add:
    //
    //   ViewBag.StudentFullName  = student?.FullName ?? User.Identity.Name;
    //   ViewBag.StudentId        = student?.StudentNumber ?? "—";
    //   ViewBag.StudentAvatarUrl = student?.ProfilePhotoUrl;   // null → initials
    //   ViewBag.InboxUnreadCount  = await _inboxService.GetUnreadCountAsync(userId);
    //   ViewBag.NotifUnreadCount  = await _notifService.GetUnreadCountAsync(userId);
