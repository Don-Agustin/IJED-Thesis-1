@{
    Layout = "_Dashboard";
    ViewBag.Title = "Admin Dashboard";
    ViewBag.PageTitle = "Dashboard";
}

@model SchoolManagementSystem.Models.DashboardViewModel

<!-- ═══════════════ STAT CARDS ═══════════════ -->
<div class="row g-3 mb-4">

    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon stat-icon--blue">
                <i class="fas fa-user-graduate"></i>
            </div>
            <div class="stat-info">
                <span class="stat-value">@Model.TotalStudents</span>
                <span class="stat-label">Total Students</span>
            </div>
            <span class="stat-sub">@Model.ActiveStudents active</span>
        </div>
    </div>

    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon stat-icon--green">
                <i class="fas fa-chalkboard-teacher"></i>
            </div>
            <div class="stat-info">
                <span class="stat-value">@Model.TotalTeachers</span>
                <span class="stat-label">Teachers</span>
            </div>
            <span class="stat-sub">@Model.TotalClasses classes</span>
        </div>
    </div>

    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon stat-icon--maroon">
                <i class="fas fa-book"></i>
            </div>
            <div class="stat-info">
                <span class="stat-value">@Model.TotalCourses</span>
                <span class="stat-label">Courses</span>
            </div>
            <span class="stat-sub">@Model.TotalSubjects subjects</span>
        </div>
    </div>

    <div class="col-6 col-xl-3">
        <div class="stat-card @(Model.AttendanceRate < 75 ? "stat-card--warn" : "")">
            <div class="stat-icon stat-icon--teal">
                <i class="fas fa-calendar-check"></i>
            </div>
            <div class="stat-info">
                <span class="stat-value">@Model.AttendanceRate<small>%</small></span>
                <span class="stat-label">Attendance Rate</span>
            </div>
            <div class="stat-bar">
                <div class="stat-bar-fill" style="width: @Model.AttendanceRate%"></div>
            </div>
        </div>
    </div>

</div>

<!-- ═══════════════ BOTTOM ROW ═══════════════ -->
<div class="row g-3">

    <!-- Recent Students -->
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-user-graduate me-2"></i>Recent Enrolments</span>
                <a asp-controller="Students" asp-action="Index" class="btn btn-sm btn-light">View All</a>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentStudents.Any())
                {
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>Class</th>
                                <th>Enrolled</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.RecentStudents)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="avatar-xs">@(s.FirstName[0].ToString())@(s.LastName[0].ToString())</div>
                                            @s.FirstName @s.LastName
                                        </div>
                                    </td>
                                    <td>@(s.SchoolClass?.ClassName ?? "—")</td>
                                    <td>@(s.FormattedEnrollmentDate ?? "—")</td>
                                    <td>
                                        @{
                                            var badgeCls = s.Status == SchoolManagementSystem.Data.Entities.StudentStatus.Active
                                            ? "badge-pass" : s.Status == SchoolManagementSystem.Data.Entities.StudentStatus.Pending
                                            ? "badge-pending" : "badge-fail";
                                        }
                                        <span class="badge @badgeCls">@s.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-4 text-center text-muted">No students enrolled yet.</div>
                }
            </div>
        </div>
    </div>

    <!-- Alerts + Quick Links -->
    <div class="col-lg-5">

        <!-- Active Alerts -->
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>
                    <i class="fas fa-bell me-2"></i>Active Alerts
                    @if (Model.UnresolvedAlerts > 0)
                    {
                        <span class="badge bg-danger ms-1">@Model.UnresolvedAlerts</span>
                    }
                </span>
                <a asp-controller="Alert" asp-action="UnresolvedAlerts" class="btn btn-sm btn-light">Manage</a>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentAlerts.Any())
                {
                    <ul class="alert-list">
                        @foreach (var alert in Model.RecentAlerts)
                        {
                            <li class="alert-item">
                                <i class="fas fa-exclamation-circle alert-icon"></i>
                                <span class="alert-text">@alert.Message</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="p-3 text-center text-muted" style="font-size:13px">No active alerts</div>
                }
            </div>
        </div>

        <!-- Quick Links -->
        <div class="card">
            <div class="card-header"><i class="fas fa-bolt me-2"></i>Quick Actions</div>
            <div class="card-body quick-links">
                <a asp-controller="Account" asp-action="Register" class="quick-link"><i class="fas fa-user-plus"></i>Register User</a>
                <a asp-controller="Students" asp-action="Create" class="quick-link"><i class="fas fa-user-graduate"></i>Add Student</a>
                <a asp-controller="Teachers" asp-action="Create" class="quick-link"><i class="fas fa-chalkboard-teacher"></i>Add Teacher</a>
                <a asp-controller="Courses" asp-action="Create" class="quick-link"><i class="fas fa-book"></i>New Course</a>
                <a asp-controller="SchoolClasses" asp-action="Create" class="quick-link"><i class="fas fa-school"></i>New Class</a>
                <a asp-controller="Alert" asp-action="UnresolvedAlerts" class="quick-link"><i class="fas fa-bell"></i>View Alerts</a>
            </div>
        </div>

    </div>
</div>
